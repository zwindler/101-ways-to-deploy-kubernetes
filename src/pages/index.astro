---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import FilterBar from '../components/FilterBar.astro';
import SolutionCard from '../components/SolutionCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import type { Solution } from '../types';
import solutionsData from '../../data/solutions.yaml';

// Load solutions data
const solutions = (solutionsData as { solutions: Solution[] }).solutions;

// Extract unique categories, cloud providers, and tags for filters
// Sort categories by length to optimize space usage in filter pills (shortest first for better packing)
const categories = [...new Set(solutions.map((s) => s.category))].sort(
  (a, b) => a.length - b.length,
);
const cloudProviders = [...new Set(solutions.flatMap((s) => s.cloud_providers || []))].sort();
const tags = [...new Set(solutions.flatMap((s) => s.tags || []))].sort();
---

<Layout title="101 Ways to Deploy Kubernetes">
  <main class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Hero Section -->
    <header class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-8 px-4 relative">
      <div class="max-w-6xl mx-auto text-center relative">
        <!-- ThemeToggle positioned absolutely so it doesn't affect title width -->
        <div class="absolute top-0 right-0">
          <ThemeToggle />
        </div>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-3 px-2">
          <!-- Mobile title (< 768px) -->
          <span class="md:hidden">101 ways<br />to deploy k8s</span>
          <!-- Desktop title (>= 768px) -->
          <span class="hidden md:inline"
            ><span class="text-gray-400">(more than)</span> 101 ways<br />to deploy Kubernetes</span
          >
        </h1>
        <p class="text-xl text-blue-100 mb-6 px-2">
          A comprehensive list of {solutions.length} ways to deploy Kubernetes!
        </p>

        <!-- Search Bar -->
        <div id="search">
          <SearchBar />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 py-8">
      <!-- Filter Bar -->
      <div id="filters">
        <FilterBar categories={categories} cloudProviders={cloudProviders} tags={tags} />
      </div>

      <!-- Results count -->
      <div class="mb-6 text-gray-600 dark:text-gray-400">
        <span id="results-count">{solutions.length}</span> solutions
      </div>

      <!-- Solutions Grid -->
      <div id="main-content" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          solutions.map((solution) => (
            <div
              class="solution-item"
              data-category={solution.category}
              data-name={solution.name.toLowerCase()}
              data-publisher={solution.publisher?.toLowerCase() || ''}
              data-description={solution.description?.toLowerCase() || ''}
              data-tags={solution.tags?.join(' ').toLowerCase() || ''}
              data-based-on={solution.based_on?.join(' ').toLowerCase() || ''}
              data-cloud-providers={solution.cloud_providers?.join(' ').toLowerCase() || ''}
              data-open-source={solution.open_source ? 'true' : 'false'}
              data-production-ready={solution.production_ready ? 'true' : 'false'}
              data-abandoned={solution.abandoned ? 'true' : 'false'}
              data-stars={solution.stars?.toString() || '0'}
            >
              <SolutionCard solution={solution} />
            </div>
          ))
        }
      </div>

      <!-- No results message -->
      <div id="no-results" class="hidden text-center py-12">
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          No solutions match your search criteria.
        </p>
        <button id="reset-filters" class="mt-4 text-blue-600 hover:underline">
          Clear all filters
        </button>
      </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-100 dark:bg-gray-800 py-8 mt-12">
      <div class="max-w-6xl mx-auto px-4 text-center text-gray-600 dark:text-gray-400">
        <p>
          Created by <a href="https://github.com/zwindler" class="text-blue-600 hover:underline"
            >@zwindler</a
          >
        </p>
        <p class="mt-2 text-sm">
          Licensed under CC BY-SA 4.0 •
          <a
            href="https://github.com/zwindler/101-ways-to-deploy-kubernetes"
            class="hover:underline">Contribute on GitHub</a
          >
        </p>
      </div>
    </footer>
  </main>
</Layout>

<script>
  // ==========================================================================
  // URL-based filter state (Issue #15 from improvement report)
  // Filters are encoded in query params so users can bookmark/share filtered views
  // ==========================================================================

  const defaultFilters = {
    category: 'all',
    cloudProvider: '',
    openSourceOnly: false,
    productionReadyOnly: false,
    status: 'all',
    tags: [] as string[],
    minStars: 0,
  };

  // ---- URL <-> State serialization ----

  function filtersToParams(search: string, filters: typeof defaultFilters): URLSearchParams {
    const params = new URLSearchParams();
    if (search) params.set('q', search);
    if (filters.category !== 'all') params.set('category', filters.category);
    if (filters.cloudProvider) params.set('cloud', filters.cloudProvider);
    if (filters.openSourceOnly) params.set('oss', '1');
    if (filters.productionReadyOnly) params.set('prod', '1');
    if (filters.status !== 'all') params.set('status', filters.status);
    if (filters.tags.length > 0) params.set('tags', filters.tags.join(','));
    if (filters.minStars > 0) params.set('stars', filters.minStars.toString());
    return params;
  }

  function paramsToState(params: URLSearchParams): {
    search: string;
    filters: typeof defaultFilters;
  } {
    return {
      search: params.get('q') || '',
      filters: {
        category: params.get('category') || 'all',
        cloudProvider: params.get('cloud') || '',
        openSourceOnly: params.get('oss') === '1',
        productionReadyOnly: params.get('prod') === '1',
        status: params.get('status') || 'all',
        tags: params.get('tags') ? params.get('tags')!.split(',').filter(Boolean) : [],
        minStars: params.get('stars') ? parseInt(params.get('stars')!, 10) : 0,
      },
    };
  }

  function pushStateToUrl(search: string, filters: typeof defaultFilters) {
    const params = filtersToParams(search, filters);
    const qs = params.toString();
    const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
    history.replaceState(null, '', url);
  }

  // ---- State ----

  const initialState = paramsToState(new URLSearchParams(window.location.search));
  let currentSearch = initialState.search;
  let currentFilters = { ...initialState.filters };

  // ---- Search highlight (Issue #19) ----

  function highlightSearchMatches(query: string) {
    const cards = document.querySelectorAll('.solution-card-wrapper');
    cards.forEach((card) => {
      const heading = card.querySelector('h3');
      if (!heading) return;

      // Store original text on first encounter
      if (!heading.hasAttribute('data-original-text')) {
        heading.setAttribute('data-original-text', heading.textContent || '');
      }
      const original = heading.getAttribute('data-original-text') || '';

      if (!query) {
        // Restore original text (remove any <mark> wrappers)
        heading.textContent = original;
        return;
      }

      // Escape regex special chars in query
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp(`(${escaped})`, 'gi');
      if (regex.test(original)) {
        heading.innerHTML = original.replace(
          regex,
          '<mark class="bg-yellow-200 dark:bg-yellow-700 dark:text-white rounded px-0.5">$1</mark>',
        );
      } else {
        heading.textContent = original;
      }
    });
  }

  // ---- Filtering logic ----

  function filterSolutions() {
    const items = document.querySelectorAll('.solution-item');
    let visibleCount = 0;

    items.forEach((item) => {
      const el = item as HTMLElement;
      let visible = true;

      // Search filter
      if (currentSearch) {
        const searchableText = [
          el.dataset.name,
          el.dataset.publisher,
          el.dataset.description,
          el.dataset.tags,
          el.dataset.basedOn,
        ].join(' ');
        visible = searchableText.includes(currentSearch);
      }

      // Category filter
      if (visible && currentFilters.category !== 'all') {
        visible = el.dataset.category === currentFilters.category;
      }

      // Cloud provider filter
      if (visible && currentFilters.cloudProvider) {
        visible = el.dataset.cloudProviders?.includes(currentFilters.cloudProvider) || false;
      }

      // Open source filter
      if (visible && currentFilters.openSourceOnly) {
        visible = el.dataset.openSource === 'true';
      }

      // Production ready filter
      if (visible && currentFilters.productionReadyOnly) {
        visible = el.dataset.productionReady === 'true';
      }

      // Status filter
      if (visible && currentFilters.status !== 'all') {
        const isAbandoned = el.dataset.abandoned === 'true';
        const itemStatus = isAbandoned ? 'abandoned' : 'active';
        visible = itemStatus === currentFilters.status;
      }

      // Tags filter
      if (visible && currentFilters.tags.length > 0) {
        const itemTags = el.dataset.tags?.split(' ') || [];
        const normalizedFilterTags = currentFilters.tags.map((tag) => tag.toLowerCase());
        visible = normalizedFilterTags.some((tag) => itemTags.includes(tag));
      }

      // Stars filter
      if (visible && currentFilters.minStars > 0) {
        const itemStars = parseInt(el.dataset.stars || '0', 10);
        visible = itemStars >= currentFilters.minStars;
      }

      el.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Highlight matching text in visible card names (Issue #19)
    highlightSearchMatches(currentSearch);

    // Update count
    const countEl = document.getElementById('results-count');
    if (countEl) countEl.textContent = visibleCount.toString();

    // Show/hide no results message
    const noResults = document.getElementById('no-results');
    const grid = document.getElementById('solutions-grid');
    if (noResults && grid) {
      noResults.classList.toggle('hidden', visibleCount > 0);
      grid.classList.toggle('hidden', visibleCount === 0);
    }

    // Dispatch count update for SearchBar
    window.dispatchEvent(
      new CustomEvent('solutions-count-update', {
        detail: { count: visibleCount },
      }),
    );

    // Sync URL
    pushStateToUrl(currentSearch, currentFilters);
  }

  // Listen for search changes
  window.addEventListener('search-change', ((e: CustomEvent) => {
    currentSearch = e.detail.query;
    filterSolutions();
  }) as EventListener);

  // Listen for filter changes
  window.addEventListener('filter-change', ((e: CustomEvent) => {
    currentFilters = { ...currentFilters, ...e.detail };
    filterSolutions();
  }) as EventListener);

  // Listen for detailed view changes
  let cachedCards: NodeListOf<Element> | null = null;
  window.addEventListener('detailed-view-change', ((e: CustomEvent) => {
    const isDetailed = e.detail.isDetailed;
    // Cache cards on first use for better performance
    if (!cachedCards) {
      cachedCards = document.querySelectorAll('.solution-card-wrapper');
    }
    cachedCards.forEach((card) => {
      if (isDetailed) {
        card.classList.add('show-detailed');
      } else {
        card.classList.remove('show-detailed');
      }
    });
  }) as EventListener);

  // Reset filters button
  document.getElementById('reset-filters')?.addEventListener('click', () => {
    currentSearch = '';
    currentFilters = { ...defaultFilters, tags: [] };
    // Dispatch reset events
    window.dispatchEvent(new CustomEvent('filters-reset'));
    filterSolutions();
  });

  // ---- Restore UI from URL on page load ----
  function restoreFiltersFromUrl() {
    const hasParams = window.location.search.length > 1;
    if (!hasParams) {
      filterSolutions();
      return;
    }

    // Tell FilterBar and SearchBar to restore their UI from this state
    window.dispatchEvent(
      new CustomEvent('filters-restore', {
        detail: {
          search: currentSearch,
          filters: currentFilters,
        },
      }),
    );

    filterSolutions();
  }

  document.addEventListener('DOMContentLoaded', () => {
    restoreFiltersFromUrl();
  });
</script>

<script>
  // Staggered fade-in animation for solution cards on page load (Issue #24: avoids forced reflow)
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.solution-item');
    // Batch all DOM writes in a single rAF to avoid layout thrashing
    requestAnimationFrame(() => {
      const limit = Math.min(cards.length, 15);
      for (let i = 0; i < limit; i++) {
        const el = cards[i] as HTMLElement;
        el.style.cssText = `opacity:0;animation:fadeInUp 0.5s ease-out ${i * 50}ms forwards`;
      }
    });
  });
</script>

<script>
  // ==========================================================================
  // Global modal manager - single delegated handler for all solution cards
  // Creates modals lazily on first click (Issue #2 + #6 from improvement report)
  // ==========================================================================

  // Language code to flag emoji mapping
  const languageToCountry: Record<string, string> = {
    en: 'GB',
    fr: 'FR',
    de: 'DE',
    es: 'ES',
    zh: 'CN',
    ja: 'JP',
    pt: 'PT',
    ko: 'KR',
    it: 'IT',
    ru: 'RU',
    nl: 'NL',
    pl: 'PL',
    tr: 'TR',
    ar: 'SA',
    hi: 'IN',
  };

  const languageNames: Record<string, string> = {
    en: 'English',
    fr: 'French',
    de: 'German',
    es: 'Spanish',
    zh: 'Chinese',
    ja: 'Japanese',
    pt: 'Portuguese',
    ko: 'Korean',
    it: 'Italian',
    ru: 'Russian',
    nl: 'Dutch',
    pl: 'Polish',
    tr: 'Turkish',
    ar: 'Arabic',
    hi: 'Hindi',
  };

  function languageToFlag(langCode: string): string {
    const cc = languageToCountry[langCode.toLowerCase()];
    if (!cc) return langCode;
    const REGIONAL_A = 0x1f1e6;
    return String.fromCodePoint(...[...cc].map((c) => REGIONAL_A + c.charCodeAt(0) - 65));
  }

  function languageToName(langCode: string): string {
    return languageNames[langCode.toLowerCase()] || langCode;
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  interface SolutionData {
    name: string;
    category: string;
    url: string;
    icon_url: string | null;
    icon_background_color: string | null;
    publisher: string | null;
    description: string | null;
    license: string | null;
    tldr_legal_url: string | null;
    open_source: boolean;
    based_on: string[];
    tags: string[];
    cloud_providers: string[];
    abandoned: boolean;
    production_ready: boolean;
    stars: number | null;
    references: {
      title: string;
      description: string | null;
      language: string;
      url: string;
      type: string;
    }[];
    firstLetter: string;
    isGitHub: boolean;
    iconBgClasses: string;
  }

  // Cache: cardId -> parsed solution data
  const dataCache = new Map<string, SolutionData>();

  function getSolutionData(cardId: string): SolutionData | null {
    if (dataCache.has(cardId)) return dataCache.get(cardId)!;
    const script = document.querySelector(`script.solution-data[data-card-id="${cardId}"]`);
    if (!script) return null;
    try {
      const data = JSON.parse(script.textContent || '');
      dataCache.set(cardId, data);
      return data;
    } catch {
      return null;
    }
  }

  // Build the modal DOM from solution data
  function buildModalHTML(cardId: string, s: SolutionData): string {
    const e = escapeHtml;

    // Logo section
    let logoHtml: string;
    if (s.icon_url) {
      logoHtml = `
        <div class="w-32 h-32 rounded-lg flex items-center justify-center flex-shrink-0 ${e(s.iconBgClasses)}" data-fallback-letter="${e(s.firstLetter)}">
          <img src="${e(s.icon_url)}" alt="${e(s.name)} logo" class="icon-img w-full h-full object-contain" width="128" height="128" decoding="async" fetchpriority="low" referrerpolicy="no-referrer" />
        </div>`;
    } else {
      logoHtml = `
        <div class="w-32 h-32 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 dark:from-blue-600 dark:to-blue-700 flex items-center justify-center text-white font-bold text-5xl flex-shrink-0">
          ${e(s.firstLetter)}
        </div>`;
    }

    // Abandoned badge
    const abandonedHtml = s.abandoned
      ? `<div class="inline-block px-4 py-2 rounded-lg text-sm font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300">Status: Abandoned</div>`
      : '';

    // Description
    const descHtml = s.description
      ? `<div><h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Description</h3><p class="text-gray-600 dark:text-gray-400 leading-relaxed">${e(s.description)}</p></div>`
      : '';

    // Based On
    const basedOnHtml =
      s.based_on.length > 0
        ? `<div class="flex-1 min-w-0"><h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Based On</h3><div class="flex flex-wrap gap-2">${s.based_on.map((t) => `<span class="px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 rounded-full text-sm font-medium">${e(t)}</span>`).join('')}</div></div>`
        : '';

    // Tags
    const tagsHtml =
      s.tags.length > 0
        ? `<div class="flex-1 min-w-0 md:text-right"><h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Tags</h3><div class="flex flex-wrap gap-2 md:justify-end">${s.tags.map((t) => `<span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full text-sm font-medium">${e(t)}</span>`).join('')}</div></div>`
        : '';

    // Combined based-on + tags row
    const basedOnTagsHtml =
      basedOnHtml || tagsHtml
        ? `<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">${basedOnHtml}${tagsHtml}</div>`
        : '';

    // Cloud providers
    const cloudHtml =
      s.cloud_providers.length > 0
        ? `<div><h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Cloud Providers</h3><div class="flex flex-wrap gap-2">${s.cloud_providers.map((p) => `<span class="px-3 py-2 bg-cyan-100 dark:bg-cyan-900/30 text-cyan-800 dark:text-cyan-300 rounded-lg text-sm font-medium">${e(p)}</span>`).join('')}</div></div>`
        : '';

    // References
    const refsHtml =
      s.references.length > 0
        ? `<div><h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">References (${s.references.length})</h3><div class="space-y-3">${s.references
            .map(
              (ref) => `
          <a href="${e(ref.url)}" target="_blank" rel="noopener noreferrer" class="block p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors border border-gray-200 dark:border-gray-600 hover:border-blue-500 dark:hover:border-blue-400">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium text-gray-900 dark:text-white">${e(ref.title)}</span>
                  <span class="text-base" title="${e(languageToName(ref.language))}" role="img">${languageToFlag(ref.language)}</span>
                  <span class="text-xs px-2 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 rounded">${e(ref.type)}</span>
                </div>
                ${ref.description ? `<p class="text-sm text-gray-600 dark:text-gray-400 mt-1">${e(ref.description)}</p>` : ''}
              </div>
              <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </div>
          </a>`,
            )
            .join('')}</div></div>`
        : '';

    // Additional info badges
    const licenseInfoHtml = s.license
      ? `<div class="flex items-center gap-2 text-gray-600 dark:text-gray-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>${s.tldr_legal_url ? `<span>License: <a href="${e(s.tldr_legal_url)}" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors underline decoration-dotted underline-offset-2">${e(s.license)}</a></span>` : `<span>License: ${e(s.license)}</span>`}</div>`
      : '';

    const ossInfoHtml = s.open_source
      ? `<div class="flex items-center gap-2 text-green-600 dark:text-green-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>Open Source</span></div>`
      : '';

    const prodInfoHtml = s.production_ready
      ? `<div class="flex items-center gap-2 text-blue-600 dark:text-blue-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>Production Ready</span></div>`
      : '';

    const starsInfoHtml = s.stars
      ? `<div class="flex items-center gap-2 text-yellow-600 dark:text-yellow-400"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><span>Stars: ${s.stars.toLocaleString()}</span></div>`
      : '';

    // Visit button
    const visitIcon = s.isGitHub
      ? `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`
      : `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>`;
    const visitLabel = s.isGitHub ? 'Visit on GitHub' : 'Visit Website';

    return `
    <div class="modal-content bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-4xl w-full max-h-[85vh] overflow-y-auto transform transition-all duration-300 scale-95 opacity-0">
      <div class="sticky top-0 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 p-6 flex items-start justify-between z-10">
        <div class="flex items-start gap-4 flex-1 min-w-0">
          ${logoHtml}
          <div class="flex-1 min-w-0">
            <h2 id="modal-title-${e(cardId)}" class="text-2xl font-bold text-gray-900 dark:text-white mb-2">${e(s.name)}</h2>
            ${s.publisher ? `<p class="text-gray-600 dark:text-gray-400 mb-2">${e(s.publisher)}</p>` : ''}
            <span class="inline-block px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 rounded-full text-sm font-medium">${e(s.category)}</span>
          </div>
        </div>
        <button class="modal-close flex-shrink-0 ml-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" aria-label="Close modal" type="button">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-6 space-y-6">
        ${abandonedHtml}
        ${descHtml}
        ${basedOnTagsHtml}
        ${cloudHtml}
        ${refsHtml}
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <div class="flex flex-wrap gap-4 text-sm">
            ${licenseInfoHtml}${ossInfoHtml}${prodInfoHtml}${starsInfoHtml}
          </div>
        </div>
        <div class="pt-4">
          <a href="${e(s.url)}" target="_blank" rel="noopener noreferrer" class="btn-press w-full flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-lg transition-colors">
            ${visitIcon} ${e(visitLabel)}
          </a>
        </div>
      </div>
    </div>`;
  }

  // ---- Modal state ----
  let activeModal: HTMLElement | null = null;
  let activeModalContent: HTMLElement | null = null;
  let triggerCard: HTMLElement | null = null;
  let savedBodyOverflow = '';
  let focusTrapHandler: ((e: KeyboardEvent) => void) | null = null;

  function openModal(cardId: string, card: HTMLElement) {
    const data = getSolutionData(cardId);
    if (!data) return;

    // Reuse or create the overlay element (singleton)
    let overlay = document.getElementById('modal-overlay');
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.id = 'modal-overlay';
      overlay.className =
        'modal-overlay fixed inset-0 bg-black bg-opacity-60 hidden items-center justify-center p-4';
      overlay.style.cssText = 'backdrop-filter: blur(8px); z-index: 9999;';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      document.body.appendChild(overlay);

      // Close on overlay click (not on content)
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal();
      });
    }

    overlay.setAttribute('aria-labelledby', `modal-title-${cardId}`);
    overlay.innerHTML = buildModalHTML(cardId, data);

    activeModal = overlay;
    activeModalContent = overlay.querySelector('.modal-content');
    triggerCard = card;

    // Show
    savedBodyOverflow = document.body.style.overflow;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';

    // Animate in
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        activeModalContent?.classList.remove('scale-95', 'opacity-0');
        activeModalContent?.classList.add('scale-100', 'opacity-100');
      });
    });

    // Focus close button
    const closeBtn = overlay.querySelector<HTMLButtonElement>('.modal-close');
    closeBtn?.focus();

    // Set up focus trap (Issue #14)
    focusTrapHandler = (e: KeyboardEvent) => {
      if (e.key !== 'Tab' || !activeModalContent) return;
      const focusable = activeModalContent.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])',
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };
    document.addEventListener('keydown', focusTrapHandler);
  }

  function closeModal() {
    if (!activeModal || !activeModalContent) return;

    // Remove focus trap
    if (focusTrapHandler) {
      document.removeEventListener('keydown', focusTrapHandler);
      focusTrapHandler = null;
    }

    activeModalContent.classList.remove('scale-100', 'opacity-100');
    activeModalContent.classList.add('scale-95', 'opacity-0');

    const modal = activeModal;
    const trigger = triggerCard;

    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.innerHTML = '';
      document.body.style.overflow = savedBodyOverflow;
      trigger?.focus();
    }, 300);

    activeModal = null;
    activeModalContent = null;
    triggerCard = null;
  }

  // ---- Delegated click handler on the grid ----
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Close button inside modal
    if (target.closest('.modal-close')) {
      closeModal();
      return;
    }

    // Don't open modal if clicking external links in footer
    if (target.closest('.btn-press')) return;

    // Card click -> open modal
    const card = target.closest<HTMLElement>('.solution-card-wrapper');
    if (card) {
      const cardId = card.dataset.cardId;
      if (cardId) openModal(cardId, card);
    }
  });

  // ---- Keyboard support for cards (Issue #13) ----
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const target = e.target as HTMLElement;
    const card = target.closest<HTMLElement>('.solution-card-wrapper');
    if (card) {
      e.preventDefault(); // Prevent scroll on Space
      const cardId = card.dataset.cardId;
      if (cardId) openModal(cardId, card);
    }
  });

  // ---- Escape key ----
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && activeModal) {
      closeModal();
    }
  });

  // ---- Icon image error fallback (Issue #3) ----
  // Delegated handler replaces inline onerror attributes on <img> elements.
  // Uses capture phase so the error is caught before it bubbles.
  document.addEventListener(
    'error',
    (e) => {
      const img = e.target as HTMLElement;
      if (!(img instanceof HTMLImageElement) || !img.classList.contains('icon-img')) return;
      img.style.display = 'none';
      const container = img.parentElement;
      if (!container) return;
      container.classList.remove('bg-white', 'dark:bg-gray-700');
      container.classList.add(
        'bg-gradient-to-br',
        'from-blue-500',
        'to-blue-600',
        'dark:from-blue-600',
        'dark:to-blue-700',
      );
      const span = document.createElement('span');
      // Card icons use text-3xl, modal icons use text-5xl
      const isModal = container.closest('.modal-content');
      span.className = `text-white font-bold ${isModal ? 'text-5xl' : 'text-3xl'}`;
      span.textContent = container.getAttribute('data-fallback-letter');
      container.appendChild(span);
    },
    true,
  );
</script>
